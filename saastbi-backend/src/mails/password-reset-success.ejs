<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= portalName %> - Password Reset Successful</title>

  <style>
    body, html {
      margin: 0;
      padding: 0;
      background-color: #F8FAFC;
      font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
      color: #0F172A;
    }

    .email-wrapper {
      width: 100%;
      padding: 20px 0;
      background-color: #F8FAFC;
    }

    .email-container {
      max-width: 600px;
      margin: 0 auto;
      background-color: #FFFFFF;
      border-radius: 16px;
      box-shadow: 0 6px 16px rgba(0, 151, 254, 0.1);
      overflow: hidden;
    }

    .email-header {
      background: linear-gradient(83.79deg, #1B45B4 3.25%, #1C2792 96.85%);
      color: #FFFFFF;
      text-align: center;
      padding: 24px 16px;
    }

    .email-header h1 {
      margin: 0;
      font-size: 20px;
      font-weight: 600;
      letter-spacing: 0.4px;
    }

    .email-body {
      padding: 32px 28px;
    }

    .email-body p {
      font-size: 15px;
      line-height: 1.7;
      margin: 0 0 14px;
      color: #0F172A;
    }

    .email-body p.muted {
      color: #475569;
      font-size: 14px;
    }

    .success-box {
      background: linear-gradient(90deg, #22C55E 0%, #16A34A 100%);
      color: #FFFFFF;
      font-size: 18px;
      font-weight: 600;
      text-align: center;
      border-radius: 10px;
      padding: 16px 12px;
      margin: 24px 0;
    }

    .verify-btn {
      display: inline-block;
      background-color: #0097FE;
      color: #FFFFFF;
      text-decoration: none;
      padding: 12px 28px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 15px;
      margin-top: 10px;
    }

    .email-footer {
      text-align: center;
      background-color: #F8FAFC;
      padding: 20px;
      font-size: 13px;
      color: #475569;
      border-top: 1px solid rgba(0,151,254,0.1);
    }

    .email-footer a {
      color: #0097FE;
      text-decoration: none;
    }

    @media only screen and (max-width: 600px) {
      .email-body {
        padding: 24px 18px;
      }

      .success-box {
        font-size: 16px;
      }

      .verify-btn {
        font-size: 14px;
        padding: 10px 22px;
      }
    }
  </style>
</head>

<body>
  <div class="email-wrapper">
    <div class="email-container">

      <!-- HEADER -->
      <div class="email-header">
        <h1><%= portalName %></h1>
      </div>

      <!-- BODY -->
      <div class="email-body">
        <p>Hi <strong><%= firstName %></strong>,</p>

        <p>
          This is to confirm that your password for the
          <strong><%= portalName %></strong> account has been successfully reset.
        </p>

        <div class="success-box">
          Your password has been updated successfully.
        </div>

        <p>
          You can now log in using your new password. For security reasons,
          all active sessions have been signed out.
        </p>

        <p class="muted">
          If you did not perform this action, please contact our support team immediately.
        </p>

        <p style="margin-top: 24px;">
          <a href="#" class="verify-btn">Go to Login</a>
        </p>

        <p style="margin-top: 32px;">
          Best regards,<br />
          <strong>Team <%= portalName %></strong>
        </p>
      </div>

      <!-- FOOTER -->
      <div class="email-footer">
        <p>&copy; <%= new Date().getFullYear() %> OPERNOVA TECHNOLOGIES LLP. All rights reserved.</p>
      </div>

    </div>
  </div>
</body>
</html>
