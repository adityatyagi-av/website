<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add-on Request Update</title>

  <style>
    body, html {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      background-color: #F8FAFC;
      font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
      color: #0F172A;
    }

    .email-wrapper {
      width: 100%;
      background-color: #F8FAFC;
      padding: 20px 0;
    }

    .email-container {
      max-width: 600px;
      background: #FFFFFF;
      margin: 0 auto;
      border-radius: 16px;
      box-shadow: 0 6px 16px rgba(0, 151, 254, 0.1);
      overflow: hidden;
    }

    .email-header {
      background: linear-gradient(83.79deg, #1B45B4 3.25%, #1C2792 96.85%);
      color: #FFFFFF;
      text-align: center;
      padding: 24px 16px;
    }

    .email-header h1 {
      margin: 0;
      font-size: 20px;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    .email-body {
      padding: 32px 28px;
    }

    .email-body p {
      font-size: 15px;
      line-height: 1.7;
      color: #0F172A;
      margin: 0 0 12px;
    }

    .email-body p.muted {
      color: #475569;
      font-size: 14px;
    }

    .status-badge {
      display: inline-block;
      padding: 6px 16px;
      border-radius: 20px;
      font-size: 14px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin: 8px 0 16px;
    }

    .status-approved {
      background-color: #D1FAE5;
      color: #065F46;
    }

    .status-rejected {
      background-color: #FEE2E2;
      color: #991B1B;
    }

    .status-in-review {
      background-color: #DBEAFE;
      color: #1E40AF;
    }

    .status-completed {
      background-color: #D1FAE5;
      color: #065F46;
    }

    .status-default {
      background-color: #F1F5F9;
      color: #334155;
    }

    .notes-box {
      background-color: #F1F5F9;
      border-left: 4px solid #0097FE;
      padding: 12px 16px;
      border-radius: 0 8px 8px 0;
      margin: 16px 0;
    }

    .notes-box p {
      margin: 0;
      font-size: 14px;
      color: #334155;
      line-height: 1.6;
    }

    .email-footer {
      text-align: center;
      padding: 20px;
      background-color: #F8FAFC;
      font-size: 13px;
      color: #475569;
      border-top: 1px solid rgba(0,151,254,0.1);
    }

    .email-footer a {
      color: #0097FE;
      text-decoration: none;
    }

    @media only screen and (max-width: 600px) {
      .email-body {
        padding: 24px 18px;
      }
    }
  </style>
</head>

<body>
  <div class="email-wrapper">
    <div class="email-container">

      <div class="email-header">
        <h1>Add-on Request Update</h1>
      </div>

      <div class="email-body">
        <p>Hi <strong><%= userName %></strong>,</p>

        <p>Your add-on service request for <strong><%= addonName %></strong> at <strong><%= organizationName %></strong> has been updated.</p>

        <p>New Status:</p>
        <%
          let statusClass = 'status-default';
          if (newStatus === 'APPROVED') statusClass = 'status-approved';
          else if (newStatus === 'REJECTED') statusClass = 'status-rejected';
          else if (newStatus === 'IN_REVIEW') statusClass = 'status-in-review';
          else if (newStatus === 'COMPLETED') statusClass = 'status-completed';
        %>
        <span class="status-badge <%= statusClass %>"><%= newStatus.replace('_', ' ') %></span>

        <% if (adminNotes) { %>
          <p class="muted">Notes from Admin:</p>
          <div class="notes-box">
            <p><%= adminNotes %></p>
          </div>
        <% } %>

        <p class="muted">You can track the status of your request in your portal dashboard.</p>

        <p style="margin-top: 32px;">Warm regards,<br /><strong>Team OPERNOVA</strong></p>
      </div>

      <div class="email-footer">
        <p>&copy; <%= new Date().getFullYear() %> OPERNOVA TECHNOLOGIES LLP. All rights reserved.</p>
      </div>
    </div>
  </div>
</body>
</html>
