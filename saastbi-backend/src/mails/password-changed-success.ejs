<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OPERNOVA - Password Changed</title>

    <style>
      body,
      html {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        background-color: #f8fafc;
        font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
        color: #0f172a;
      }

      .email-wrapper {
        width: 100%;
        background-color: #f8fafc;
        padding: 20px 0;
      }

      .email-container {
        max-width: 600px;
        background: #ffffff;
        margin: 0 auto;
        border-radius: 16px;
        box-shadow: 0 6px 16px rgba(0, 151, 254, 0.1);
        overflow: hidden;
      }

      /* Header */
      .email-header {
        background: linear-gradient(83.79deg, #1b45b4 3.25%, #1c2792 96.85%);
        color: #ffffff;
        text-align: center;
        padding: 24px 16px;
      }

      .email-header h1 {
        margin: 0;
        font-size: 20px;
        font-weight: 600;
        letter-spacing: 0.5px;
      }

      /* Body */
      .email-body {
        padding: 32px 28px;
      }

      .email-body p {
        font-size: 15px;
        line-height: 1.7;
        color: #0f172a;
        margin: 0 0 12px;
      }

      .email-body p.muted {
        color: #475569;
        font-size: 14px;
      }

      /* Success Box */
      .success-box {
        background: linear-gradient(90deg, #16a34a 0%, #22c55e 100%);
        color: #ffffff;
        font-size: 18px;
        font-weight: 600;
        text-align: center;
        border-radius: 10px;
        padding: 16px;
        margin: 24px 0;
      }

      /* CTA Button */
      .action-btn {
        display: inline-block;
        background-color: #0097fe;
        color: #ffffff;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 15px;
      }

      .action-btn:hover {
        background: linear-gradient(
          277deg,
          rgba(0, 151, 254, 0) 8.72%,
          rgba(0, 151, 254, 0.86) 91.5%
        );
      }

      /* Footer */
      .email-footer {
        text-align: center;
        padding: 20px;
        background-color: #f8fafc;
        font-size: 13px;
        color: #475569;
        border-top: 1px solid rgba(0, 151, 254, 0.1);
      }

      .email-footer a {
        color: #0097fe;
        text-decoration: none;
      }

      .email-footer a:hover {
        text-decoration: underline;
      }

      /* Responsive */
      @media only screen and (max-width: 600px) {
        .email-body {
          padding: 24px 18px;
        }

        .success-box {
          font-size: 16px;
        }

        .action-btn {
          font-size: 14px;
          padding: 10px 20px;
        }
      }
    </style>
  </head>

  <body>
    <div class="email-wrapper">
      <div class="email-container">
        <!-- HEADER -->
        <div class="email-header">
          <h1>Opernova Social Plaform</h1>
        </div>

        <!-- BODY -->
        <div class="email-body">
          <p>Hi <strong><%= firstName %></strong>,</p>

          <p>
            This is a confirmation that your password for
            <strong>Opernova Social Platform</strong> has been changed successfully.
          </p>

          <div class="success-box"> Your password has been updated</div>

          <p class="muted">
            If you made this change, no further action is required.
          </p>

          <p class="muted">
            If you did <strong>not</strong> change your password, please contact
            our support team immediately to secure your account.
          </p>

          <p style="margin-top: 24px">
            <a href="#" class="action-btn">Go to Portal</a>
          </p>

          <p style="margin-top: 32px">
            Stay safe,<br />
            <strong>Team OPERNOVA</strong>
          </p>
        </div>

        <!-- FOOTER -->
        <div class="email-footer">
        <p>
          Need help?
          Contact us at
          <a href="mailto:<%= supportEmail %>"><%= supportEmail %></a>
        </p>
        <p>
          &copy; OPERNOVA TECHNOLOGIES LLP.
          All rights reserved.
        </p>
      </div>
      </div>
    </div>
  </body>
</html>
