<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>New Add-on Service Request</title>

  <style>
    body, html {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      background-color: #F8FAFC;
      font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
      color: #0F172A;
    }

    .email-wrapper {
      width: 100%;
      background-color: #F8FAFC;
      padding: 20px 0;
    }

    .email-container {
      max-width: 600px;
      background: #FFFFFF;
      margin: 0 auto;
      border-radius: 16px;
      box-shadow: 0 6px 16px rgba(0, 151, 254, 0.1);
      overflow: hidden;
    }

    .email-header {
      background: linear-gradient(83.79deg, #1B45B4 3.25%, #1C2792 96.85%);
      color: #FFFFFF;
      text-align: center;
      padding: 24px 16px;
    }

    .email-header h1 {
      margin: 0;
      font-size: 20px;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    .email-body {
      padding: 32px 28px;
    }

    .email-body p {
      font-size: 15px;
      line-height: 1.7;
      color: #0F172A;
      margin: 0 0 12px;
    }

    .email-body p.muted {
      color: #475569;
      font-size: 14px;
    }

    .detail-table {
      width: 100%;
      border-collapse: collapse;
      margin: 20px 0;
    }

    .detail-table td {
      padding: 10px 12px;
      font-size: 14px;
      border-bottom: 1px solid #E2E8F0;
    }

    .detail-table td:first-child {
      color: #475569;
      font-weight: 500;
      width: 40%;
    }

    .detail-table td:last-child {
      color: #0F172A;
      font-weight: 600;
    }

    .badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .badge-fixed {
      background-color: #DBEAFE;
      color: #1E40AF;
    }

    .badge-custom {
      background-color: #FEF3C7;
      color: #92400E;
    }

    .message-box {
      background-color: #F1F5F9;
      border-left: 4px solid #0097FE;
      padding: 12px 16px;
      border-radius: 0 8px 8px 0;
      margin: 16px 0;
    }

    .message-box p {
      margin: 0;
      font-size: 14px;
      color: #334155;
      line-height: 1.6;
    }

    .email-footer {
      text-align: center;
      padding: 20px;
      background-color: #F8FAFC;
      font-size: 13px;
      color: #475569;
      border-top: 1px solid rgba(0,151,254,0.1);
    }

    .email-footer a {
      color: #0097FE;
      text-decoration: none;
    }

    @media only screen and (max-width: 600px) {
      .email-body {
        padding: 24px 18px;
      }
    }
  </style>
</head>

<body>
  <div class="email-wrapper">
    <div class="email-container">

      <div class="email-header">
        <h1>New Add-on Service Request</h1>
      </div>

      <div class="email-body">
        <p>Hi <strong><%= adminName %></strong>,</p>

        <p>A new add-on service request has been submitted by <strong><%= organizationName %></strong>.</p>

        <table class="detail-table">
          <tr>
            <td>Add-on Service</td>
            <td><%= addonName %></td>
          </tr>
          <tr>
            <td>Type</td>
            <td>
              <span class="badge <%= addonType === 'FIXED' ? 'badge-fixed' : 'badge-custom' %>">
                <%= addonType %>
              </span>
            </td>
          </tr>
          <tr>
            <td>Requested By</td>
            <td><%= requesterName %></td>
          </tr>
          <tr>
            <td>Email</td>
            <td><%= requesterEmail %></td>
          </tr>
          <tr>
            <td>Phone</td>
            <td><%= phone %></td>
          </tr>
          <tr>
            <td>Preferred Date</td>
            <td><%= preferredDate %></td>
          </tr>
          <tr>
            <td>Preferred Time</td>
            <td><%= preferredTime %></td>
          </tr>
        </table>

        <% if (message && message !== 'No additional message') { %>
          <p class="muted">Additional Message:</p>
          <div class="message-box">
            <p><%= message %></p>
          </div>
        <% } %>

        <p class="muted">Please review this request in the Super Admin dashboard.</p>

        <p style="margin-top: 32px;">Warm regards,<br /><strong>Team OPERNOVA</strong></p>
      </div>

      <div class="email-footer">
        <p>&copy; <%= new Date().getFullYear() %> OPERNOVA TECHNOLOGIES LLP. All rights reserved.</p>
      </div>
    </div>
  </div>
</body>
</html>
