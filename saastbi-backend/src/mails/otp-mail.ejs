<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= portalName %> - OTP Verification</title>

  <style>
    /* General Reset */
    body, html {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      background-color: #F8FAFC; /* Neutral Background */
      font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
      color: #0F172A; /* Dark Text */
    }

    .email-wrapper {
      width: 100%;
      background-color: #F8FAFC;
      padding: 20px 0;
    }

    .email-container {
      max-width: 600px;
      background: #FFFFFF; /* White card background */
      margin: 0 auto;
      border-radius: 16px;
      box-shadow: 0 6px 16px rgba(0, 151, 254, 0.1);
      overflow: hidden;
    }

    /* Header */
    .email-header {
      background: linear-gradient(83.79deg, #1B45B4 3.25%, #1C2792 96.85%);
      color: #FFFFFF;
      text-align: center;
      padding: 24px 16px;
    }

    .email-header h1 {
      margin: 0;
      font-size: 20px;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    /* Content */
    .email-body {
      padding: 32px 28px;
    }

    .email-body p {
      font-size: 15px;
      line-height: 1.7;
      color: #0F172A;
      margin: 0 0 12px;
    }

    .email-body p.muted {
      color: #475569; /* Muted Text */
      font-size: 14px;
    }

    /* OTP Box */
    .otp-box {
      background: linear-gradient(90deg, #5433FF 0%, #20BDFF 50%, #A5FECB 100%);
      color: #FFFFFF;
      font-size: 28px;
      font-weight: bold;
      letter-spacing: 6px;
      text-align: center;
      border-radius: 10px;
      padding: 16px 0;
      margin: 24px 0;
    }

    /* CTA Button (for aesthetic consistency) */
    .verify-btn {
      display: inline-block;
      background-color: #0097FE;
      color: #FFFFFF;
      text-decoration: none;
      padding: 12px 24px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 15px;
      transition: background 0.2s ease-in-out;
    }

    .verify-btn:hover {
      background: linear-gradient(277deg, rgba(0,151,254,0) 8.72%, rgba(0,151,254,0.86) 91.5%);
    }

    /* Footer */
    .email-footer {
      text-align: center;
      padding: 20px;
      background-color: #F8FAFC;
      font-size: 13px;
      color: #475569;
      border-top: 1px solid rgba(0,151,254,0.1);
    }

    .email-footer a {
      color: #0097FE;
      text-decoration: none;
    }

    .email-footer a:hover {
      text-decoration: underline;
    }

    /* Responsive */
    @media only screen and (max-width: 600px) {
      .email-body {
        padding: 24px 18px;
      }

      .otp-box {
        font-size: 22px;
        letter-spacing: 4px;
      }

      .verify-btn {
        font-size: 14px;
        padding: 10px 20px;
      }
    }
  </style>
</head>

<body>
  <div class="email-wrapper">
    <div class="email-container">

      <!-- HEADER -->
      <div class="email-header">
        <h1><%= portalName %></h1>
      </div>

      <!-- BODY -->
      <div class="email-body">
        <p>Hi <strong><%= adminName %></strong>,</p>

        <p>Welcome to <strong><%= organizationName %></strong> on <strong><%= portalName %></strong>!</p>
        <p>To complete your sign-up, please verify your email address using the OTP below:</p>

        <div class="otp-box"><%= otp %></div>

        <p class="muted">This OTP will expire in <%= expiryMinutes %> minutes.</p>

        <p>If you didn’t request this verification, please ignore this email.</p>

        <p style="margin-top: 24px;">
          <a href="#" class="verify-btn">Go to Portal</a>
        </p>

        <p style="margin-top: 32px;">Warm regards,<br /><strong>Team OPERNOVA</strong></p>
      </div>

      <!-- FOOTER -->
      <div class="email-footer">
        <p>Need help? Contact us at 
          <a href="mailto:<%= supportEmail %>"><%= supportEmail %></a>
        </p>
        <p>&copy; <%= new Date().getFullYear() %> OPERNOVA TECHNOLOGIES LLP. All rights reserved.</p>
      </div>
    </div>
  </div>
</body>
</html>
