  UserEducation     UserEducation[]
  UserCertification UserCertification[]
  ownedOfficeSpaces OfficeSpace[]       @relation("PageOwnedOffices")
  officeRequests    OfficeRequest[]     @relation("PageOfficeRequests")
  officeBookings    OfficeBooking[]     @relation("PageOfficeBookings")
  likes             Like[]
  bookmarks         Bookmark[]
  comments          Comment[]
  commentLikes      CommentLike[]
  shares            Share[]

  @@index([creatorId])
  @@index([type])
  @@index([slug])
}

