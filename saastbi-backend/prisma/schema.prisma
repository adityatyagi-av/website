// Events
model Event {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String
  shortDesc   String?
  coverImage  String?
  eventType   EventType
  format      EventFormat @default(IN_PERSON)
  status      EventStatus @default(DRAFT)

  authorId String
  author   User    @relation("UserHostedEvents", fields: [authorId], references: [id])
  pageId   String?
  page     Page?   @relation("PageHostedEvents", fields: [pageId], references: [id])

  startDate DateTime
  endDate   DateTime?
  timezone  String    @default("Asia/Kolkata")

  venue      String?
  address    String?
  city       String?
  state      String?
  country    String?
  latitude   Float?
  longitude  Float?
  virtualUrl String?

  capacity             Int?
  isPaid               Boolean   @default(false)
  price                Float?
  currency             String    @default("INR")
  tags                 String[]  @default([])
  isPublic             Boolean   @default(true)
  isFeatured           Boolean   @default(false)
  requiresApproval     Boolean   @default(false)
  allowWaitlist        Boolean   @default(false)
  autoConfirm          Boolean   @default(true)
  registrationDeadline DateTime?

  isLive              Boolean         @default(false)
  liveStatus          EventLiveStatus @default(NOT_STARTED)
  meetingRoomId       String?
  meetingUrl          String?
  liveViewerCount     Int             @default(0)
  maxLiveParticipants Int?

  isRecurring      Boolean            @default(false)
  recurringType    EventRecurringType @default(NONE)
  recurringDays    String[]           @default([])
  recurringEndDate DateTime?
  parentEventId    String?
  parentEvent      Event?             @relation("EventRecurrence", fields: [parentEventId], references: [id])
  childEvents      Event[]            @relation("EventRecurrence")

  viewCount         Int     @default(0)
  registrationCount Int     @default(0)
  bookmarkCount     Int     @default(0)
  isArchived        Boolean @default(false)

  contactEmail     String?
  contactPhone     String?
  websiteUrl       String?
  isCommentEnabled Boolean @default(true)

  registrations       EventRegistration[]
  organizers          EventOrganizer[]
  speakers            EventSpeaker[]
  sponsors            EventSponsor[]
  timeline            EventTimeline[]
  ticketTypes         EventTicketType[]
  bookmarks           EventBookmark[]
  liveSessions        EventLiveSession[]
  media               EventMedia[]
  feedback            EventFeedback[]
  updates             EventUpdate[]
  invitations         EventInvitation[]
  questions           EventQuestion[]
  polls               EventPoll[]
  recurrenceInstances EventRecurrenceInstance[] @relation("ParentEventInstances")
  childInstances      EventRecurrenceInstance[] @relation("ChildEventInstances")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([startDate])
  @@index([eventType])
  @@index([authorId])
  @@index([pageId])
  @@index([status])
  @@index([liveStatus])
  @@index([isRecurring])
  @@index([parentEventId])
  @@index([format])
}

model EventRegistration {
  id              String                  @id @default(cuid())
  eventId         String
  userId          String
  status          EventRegistrationStatus @default(REGISTERED)
  ticketTypeId    String?
  ticketType      EventTicketType?        @relation(fields: [ticketTypeId], references: [id])
  ticketName      String?
  ticketPrice     Float?
  attendedAt      DateTime?
  checkedInAt     DateTime?
  cancelReason    String?
  cancelledAt     DateTime?
  rejectionNote   String?
  reminder24hSent Boolean                 @default(false)
  reminder1hSent  Boolean                 @default(false)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  event           Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment         EventPayment?

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([status])
}

model EventOrganizer {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
