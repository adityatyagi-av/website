}

model EventTimeline {
  id          String    @id @default(cuid())
  eventId     String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime?
  location    String?
  speakerIds  String[]  @default([])
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model EventTicketType {
  id            String              @id @default(cuid())
  eventId       String
  name          String
  description   String?
  price         Float               @default(0)
  currency      String              @default("INR")
  quantity      Int
  quantitySold  Int                 @default(0)
  saleStartDate DateTime?
  saleEndDate   DateTime?
  isActive      Boolean             @default(true)
  order         Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  event         Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations EventRegistration[]

  @@unique([eventId, name])
  @@index([eventId])
}

model EventPayment {
  id                String             @id @default(cuid())
  registrationId    String             @unique
  userId            String
  eventId           String
  amount            Float
  currency          String             @default("INR")
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  status            EventPaymentStatus @default(PENDING)
  refundId          String?
  refundAmount      Float?
  refundStatus      RefundStatus?
  paidAt            DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  registration      EventRegistration  @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  user              User               @relation("UserEventPayments", fields: [userId], references: [id])

  @@index([registrationId])
  @@index([userId])
  @@index([eventId])
}

model EventBookmark {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation("UserEventBookmarks", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}

model EventLiveSession {
  id           String                 @id @default(cuid())
  eventId      String
  startedAt    DateTime               @default(now())
  endedAt      DateTime?
  peakViewers  Int                    @default(0)
  totalJoins   Int                    @default(0)
  recordingUrl String?
  duration     Int?
  createdAt    DateTime               @default(now())
  event        Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participants EventLiveParticipant[]

  @@index([eventId])
}

model EventLiveParticipant {
  id            String              @id @default(cuid())
  liveSessionId String
  userId        String
  role          LiveParticipantRole @default(PARTICIPANT)
  joinedAt      DateTime            @default(now())
  leftAt        DateTime?
  liveSession   EventLiveSession    @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  user          User                @relation("UserLiveParticipations", fields: [userId], references: [id])

  @@index([liveSessionId])
  @@index([userId])
}

model EventMedia {
  id        String         @id @default(cuid())
  eventId   String
  url       String
  mediaType EventMediaType @default(IMAGE)
  caption   String?
  order     Int            @default(0)
  createdAt DateTime       @default(now())
  event     Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)

