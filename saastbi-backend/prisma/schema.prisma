}

model EventInvitation {
  id            String                @id @default(cuid())
  eventId       String
  invitedById   String
  invitedUserId String
  status        EventInvitationStatus @default(PENDING)
  message       String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  event         Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitedBy     User                  @relation("EventInvitationsSent", fields: [invitedById], references: [id])
  invitedUser   User                  @relation("EventInvitationsReceived", fields: [invitedUserId], references: [id])

