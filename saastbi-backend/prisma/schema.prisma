//new and updated schema follow this 

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SuperAdmin {
  id        String          @id @default(cuid())
  name      String
  email     String          @unique
  password  String
  role      SuperAdminRoles @default(RELATIONSHIP_MANAGER)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Tenant {
  id                     String                       @id @default(cuid())
  organizationName       String
  tenantKey              String                       @unique
  domain                 String?
  status                 TenantStatus                 @default(INACTIVE)
  planId                 String?
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  tenantLogo             String?
  billingHistory         BillingHistory[]
  changeRequests         ChangeRequest[]
  chats                  Chat?
  documentRequests       DocumentRequest[]
  facilities             Facility[]
  facilityBookings       FacilityBooking[]
  userMemberships        IncubationUserTenant[]
  invoices               Invoice[]
  moduleRequests         ModuleRequest[]
  officeAllocations      OfficeAllocation[]
  officeRequests         OfficeRequest[]
  officeSpaces           OfficeSpace[]
  programs               Program[]                    @relation("TenantPrograms")
  role                   Role[]
  startupApplications    StartupApplication[]
  programAssociations    StartupProgramAssociation[]
  startupAssociations    StartupTenantAssociation[]
  mentorAssociations     IncubatorMentorAssociation[]
  subscriptions          Subscription[]               @relation("TenantSubscriptions")
  plan                   Plan?                        @relation(fields: [planId], references: [id])
  pageId                 String?                      @unique
  page                   Page?                        @relation(fields: [pageId], references: [id])
  fundingSources         TenantFundingSource[]
  fundingDisbursements   FundingDisbursement[]
  fundingHistory         FundingHistory[]
  fundingRequests        StartupFundingRequest[]
  publicRepositories     PublicRepository[]
  addonServiceRequests   AddonServiceRequest[]
  schemeQuestions        SchemeQuestion[]
  profile                TenantProfile?
  dataCollectionRequests DataCollectionRequest[]
  moduleOverrides        TenantModuleOverride[]
  payoutAccounts         IncubationPayoutAccount[]
  officePayouts          OfficePayout[]
  officeSubscriptions    OfficeSubscription[]
}

model Plan {
  id             String         @id @default(cuid())
  name           String
  price          Float
  type           PlanType       @default(MONTHLY)
  maxUsers       Int            @default(5)
  maxStartups    Int            @default(1)
  storageLimit   Int?
  features       String[]
  razorpayPlanId String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  planModules    PlanModule[]
  subscriptions  Subscription[] @relation("PlanSubscriptions")
  tenants        Tenant[]
}

model Subscription {
  id                     String             @id @default(cuid())
  tenantId               String
  planId                 String
  razorpaySubscriptionId String             @unique
  razorpayPaymentId      String?
  razorpaySignature      String?
  status                 SubscriptionStatus @default(PENDING)
  startDate              DateTime?
  endDate                DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  plan                   Plan               @relation("PlanSubscriptions", fields: [planId], references: [id])
  tenant                 Tenant             @relation("TenantSubscriptions", fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([status, endDate])
}

model PlanModule {
  id        String   @id @default(cuid())
  planId    String
  moduleId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  module    Module   @relation(fields: [moduleId], references: [id])
  plan      Plan     @relation(fields: [planId], references: [id])

  @@unique([planId, moduleId])
}

model IncubationUser {
  id                        String                     @id @default(cuid())
  name                      String
  email                     String                     @unique
  password                  String
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  imageUrl                  String?
  isActive                  Boolean                    @default(true)
  userId                    String?
  user                      User?                      @relation(fields: [userId], references: [id])
  tenantMemberships         IncubationUserTenant[]
  changeRequestsRequested   ChangeRequest[]            @relation("IncubationUserChangeRequests")
  documentRequestsRequested DocumentRequest[]          @relation("IncubationUserDocumentRequests")
  facilityBookings          FacilityBooking[]
  officeAllocations         OfficeAllocation[]
  programsManaged           ProgramManagerAssignment[]
  programsAsPanel           ProgramPanelAssignment[]
  evaluations               Evaluation[]
  permissions               UserPermission[]
  addonServiceRequests      AddonServiceRequest[]
  dataCollectionRequests    DataCollectionRequest[]
}

model IncubationUserTenant {
  id               String         @id @default(cuid())
  incubationUserId String
  tenantId         String
  roleId           String?
  isAdmin          Boolean        @default(false)
  isPanelMember    Boolean        @default(false)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  incubationUser   IncubationUser @relation(fields: [incubationUserId], references: [id])
  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  role             Role?          @relation(fields: [roleId], references: [id])

  @@unique([incubationUserId, tenantId])
  @@index([incubationUserId])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

model SchemeType {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  programs  Program[]
}

model GoverningBody {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  programs  Program[]
}

model Program {
  id                     String                      @id @default(cuid())
  tenantId               String
  title                  String
  description            String
  coverImage             String?
  programLogo            String?
  objective              String
  benefits               String
  guidelines             String
  schemeTypeId           String?
  governingBodyId        String?
  eligibilityCriteria    String
  nonEligibilityCriteria String
  expectedOutcome        String?
  externalLink           String?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  announcements          Announcement[]
  evaluationQuestions    EvaluationQuestion[]
  tenant                 Tenant                      @relation("TenantPrograms", fields: [tenantId], references: [id])
  schemeTypeRef          SchemeType?                 @relation(fields: [schemeTypeId], references: [id])
  governingBody          GoverningBody?              @relation(fields: [governingBodyId], references: [id])
  programManagers        ProgramManagerAssignment[]
  panelAssignments       ProgramPanelAssignment[]
  programSchemeQuestions ProgramSchemeQuestion[]
  startupApplications    StartupApplication[]
  startupAssociations    StartupProgramAssociation[]
  totalFundingAmount     Float?
  fundingType            ProgramFundingType?
  fundingCurrency        String?                     @default("INR")
  isFundingAvailable     Boolean                     @default(false)
  fundingAllocations     ProgramFundingAllocation[]
  fundingDisbursements   FundingDisbursement[]
  fundingRequests        StartupFundingRequest[]

  batches                ProgramBatch[]
  dataCollectionRequests DataCollectionRequest[]

  @@index([schemeTypeId])
  @@index([governingBodyId])
}

model ProgramBatch {
  id                   String              @id @default(cuid())
  programId            String
  batchName            String
  batchCode            String?
  description          String?
  applicationStartDate DateTime?
  applicationEndDate   DateTime?
  maxSlots             Int?
  status               ProgramBatchStatus  @default(DRAFT)
  isActive             Boolean             @default(true)
  totalFundingAmount   Float?
  fundingType          ProgramFundingType?
  fundingCurrency      String?             @default("INR")
  isFundingAvailable   Boolean             @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  program                Program                     @relation(fields: [programId], references: [id])
  startupApplications    StartupApplication[]
  startupAssociations    StartupProgramAssociation[]
  panelAssignments       ProgramPanelAssignment[]
  fundingAllocations     ProgramFundingAllocation[]
  fundingDisbursements   FundingDisbursement[]
  fundingRequests        StartupFundingRequest[]
  announcements          Announcement[]
  dataCollectionRequests DataCollectionRequest[]

  @@unique([programId, batchCode])
  @@index([programId])
  @@index([status])
}

model SchemeQuestion {
  id            String                  @id @default(cuid())
  tenantId      String
  questionText  String
  questionType  SchemeQuestionType
  isRequired    Boolean                 @default(false)
  options       String[]                @default([])
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  schemeAnswers SchemeAnswer[]
  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  programLinks  ProgramSchemeQuestion[]

  @@index([tenantId])
}

model ProgramSchemeQuestion {
  id               String         @id @default(cuid())
  programId        String
  schemeQuestionId String
  createdAt        DateTime       @default(now())
  program          Program        @relation(fields: [programId], references: [id])
  schemeQuestion   SchemeQuestion @relation(fields: [schemeQuestionId], references: [id])

  @@unique([programId, schemeQuestionId])
  @@index([programId])
  @@index([schemeQuestionId])
}

model EvaluationQuestion {
  id               String             @id @default(cuid())
  programId        String
  questionText     String
  weightage        Float              @default(1.0)
  order            Int                @default(0)
  isActive         Boolean            @default(true)
  scoringReference String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  options          EvaluationOption[]
  answers          EvaluationAnswer[]
  program          Program            @relation(fields: [programId], references: [id])
}

model ProgramManagerAssignment {
  id        String         @id @default(cuid())
  programId String
  managerId String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  manager   IncubationUser @relation(fields: [managerId], references: [id])
  program   Program        @relation(fields: [programId], references: [id])

  @@unique([programId, managerId])
}

model ProgramPanelAssignment {
  id            String   @id @default(cuid())
  programId     String
  panelMemberId String
  batchId       String?
  assignedById  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  panelMember IncubationUser @relation(fields: [panelMemberId], references: [id])
  program     Program        @relation(fields: [programId], references: [id])
  batch       ProgramBatch?  @relation(fields: [batchId], references: [id])

  @@unique([programId, panelMemberId, batchId])
  @@index([programId])
  @@index([panelMemberId])
  @@index([batchId])
}

model EvaluationOption {
  id         String   @id @default(cuid())
  questionId String
  optionText String
  score      Float
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question EvaluationQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  EvaluationAnswer[]

  @@index([questionId])
}

model Evaluation {
  id            String           @id @default(cuid())
  applicationId String
  evaluatorId   String
  totalScore    Float?
  remarks       String?
  status        EvaluationStatus @default(SUBMITTED)
  evaluatedAt   DateTime         @default(now())
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  application StartupApplication @relation(fields: [applicationId], references: [id])
  evaluator   IncubationUser     @relation(fields: [evaluatorId], references: [id])
  answers     EvaluationAnswer[]

  @@unique([applicationId, evaluatorId])
  @@index([applicationId])
  @@index([evaluatorId])
}

model EvaluationAnswer {
  id           String   @id @default(cuid())
  evaluationId String
  questionId   String
  optionId     String?
  score        Float?
  comment      String?
  evaluatedAt  DateTime @default(now())

  evaluation Evaluation         @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  question   EvaluationQuestion @relation(fields: [questionId], references: [id])
  option     EvaluationOption?  @relation(fields: [optionId], references: [id])

  @@index([evaluationId])
}

model Role {
  id              String                 @id @default(cuid())
  roleName        String
  tenantId        String
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  userMemberships IncubationUserTenant[]
  tenant          Tenant                 @relation(fields: [tenantId], references: [id])
  permissions     RolePermission[]

  @@unique([tenantId, roleName])
}

model Module {
  id                String                 @id @default(cuid())
  moduleName        String                 @unique
  moduleKey         String                 @unique
  moduleDescription String
  isActive          Boolean                @default(false)
  isCore            Boolean                @default(false)
  category          String?
  displayOrder      Int?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  permissions       Permission[]
  planModules       PlanModule[]
  tenantOverrides   TenantModuleOverride[]

  @@index([isActive])
  @@index([isCore])
}

model Permission {
  id             String           @id @default(cuid())
  action         String
  moduleId       String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  module         Module           @relation(fields: [moduleId], references: [id])
  rolePermission RolePermission[]
  userPermission UserPermission[]

  @@unique([moduleId, action])
  @@index([moduleId])
}

model TenantModuleOverride {
  id        String             @id @default(cuid())
  tenantId  String
  moduleId  String
  grantType ModuleOverrideType @default(INCLUDE)
  reason    String?
  grantedBy String?
  startsAt  DateTime?
  expiresAt DateTime?
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  tenant    Tenant             @relation(fields: [tenantId], references: [id])
  module    Module             @relation(fields: [moduleId], references: [id])

  @@unique([tenantId, moduleId])
  @@index([tenantId])
  @@index([moduleId])
  @@index([tenantId, isActive])
}

model AccessAuditLog {
  id        String   @id @default(cuid())
  userId    String?
  tenantId  String?
  moduleKey String
  action    String
  reason    String
  method    String?
  path      String?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([moduleKey])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@index([roleId])
  @@index([permissionId])
}

model UserPermission {
  id           String         @id @default(cuid())
  userId       String
  permissionId String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  permission   Permission     @relation(fields: [permissionId], references: [id])
  user         IncubationUser @relation(fields: [userId], references: [id])
}

model BillingHistory {
  id            String        @id @default(cuid())
  tenantId      String
  amount        Float
  description   String?
  billingDate   DateTime      @default(now())
  paymentMethod String?
  status        BillingStatus @default(SUCCESS)
  invoiceId     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  invoice       Invoice?      @relation(fields: [invoiceId], references: [id])
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
}

model Invoice {
  id             String           @id @default(cuid())
  tenantId       String
  invoiceNumber  String           @unique
  amount         Float
  issuedDate     DateTime         @default(now())
  dueDate        DateTime?
  paidDate       DateTime?
  status         InvoiceStatus    @default(UNPAID)
  pdfUrl         String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  billingHistory BillingHistory[]
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
}

model ModuleRequest {
  id         String        @id @default(cuid())
  tenantId   String
  reason     String?
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  reviewedAt DateTime?
  reviewedBy String?
  tenant     Tenant        @relation(fields: [tenantId], references: [id])
}

model Chat {
  id                String          @id @default(cuid())
  tenantId          String          @unique
  lastMessage       String?
  lastMessageAt     DateTime?
  unreadCount       Int             @default(0)
  tenantUnreadCount Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  messages          TenantMessage[]
}

model TenantMessage {
  id         String     @id @default(cuid())
  chatId     String
  senderId   String
  senderType SenderType
  content    String
  isRead     Boolean    @default(false)
  readBy     String[]   @default([])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  chat       Chat       @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
}

model Startup {
  id                        String                      @id @default(cuid())
  name                      String
  logoUrl                   String?
  description               String?
  website                   String?
  sector                    String?
  stage                     String?
  incorporationDate         DateTime?
  registrationNumber        String?
  headquarters              String?
  contactEmail              String
  contactPhone              String?
  linkedin                  String?
  foundedYear               Int?
  ideaDescription           String?
  conceptNote               String?
  aspectNote                String?
  status                    StartupRegistrationStatus   @default(CREATED)
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  pageId                    String?                     @unique
  page                      Page?                       @relation(fields: [pageId], references: [id])
  facilityBookings          FacilityBooking[]
  officeAllocations         OfficeAllocation[]
  officeRequests            OfficeRequest[]
  applications              StartupApplication[]
  files                     StartupFile[]
  programAssociations       StartupProgramAssociation[]
  tenantAssociations        StartupTenantAssociation[]
  members                   StartupMember[]
  jobs                      Job[]
  fundingRounds             FundingRound[]
  milestones                StartupMilestone[]
  pitchDecks                PitchDeck[]
  investorUpdates           InvestorUpdate[]
  metrics                   StartupMetric[]
  ownedOfficeSpaces         OfficeSpace[]               @relation("StartupOwnedOffices")
  officeBookings            OfficeBooking[]             @relation("StartupOfficeBookings")
  officePayments            OfficePayment[]             @relation("StartupOfficePayments")
  mentorSessions            MentorSession[]             @relation("StartupMentorSessions")
  mentorships               Mentorship[]                @relation("StartupMentorships")
  packageSubscriptions      PackageSubscription[]
  fundingDisbursements      FundingDisbursement[]
  fundingRequests           StartupFundingRequest[]
  dataCollectionAssignments DataCollectionAssignment[]
}

model StartupApplication {
  id                        String                     @id @default(cuid())
  startupId                 String
  programId                 String
  tenantId                  String
  batchId                   String?
  status                    StartupApplicationStatus   @default(NEW)
  submittedAt               DateTime?
  reviewedAt                DateTime?
  feedback                  String?
  score                     Float?
  currentStage              String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  meta                      Json?
  requestedFundingAmount    Float?
  fundingPurpose            String?
  history                   ApplicationHistory[]
  changeRequests            ChangeRequest[]
  documentRequests          DocumentRequest[]
  evaluations               Evaluation[]
  schemeAnswers             SchemeAnswer[]
  program                   Program                    @relation(fields: [programId], references: [id])
  startup                   Startup                    @relation(fields: [startupId], references: [id])
  tenant                    Tenant                     @relation(fields: [tenantId], references: [id])
  batch                     ProgramBatch?              @relation(fields: [batchId], references: [id])
  documents                 StartupFile[]
  disbursements             FundingDisbursement[]
  fundingRequests           StartupFundingRequest[]
  dataCollectionAssignments DataCollectionAssignment[]

  @@index([startupId, programId, status])
  @@index([batchId])
}

model ChangeRequest {
  id            String             @id @default(cuid())
  applicationId String
  tenantId      String
  requestedById String?
  requestedAt   DateTime           @default(now())
  resolvedAt    DateTime?
  title         String?
  description   String?
  status        RequestStatus      @default(PENDING)
  type          ChangeType         @default(GENERAL)
  visibleToAll  Boolean            @default(true)
  application   StartupApplication @relation(fields: [applicationId], references: [id])
  requestedBy   IncubationUser?    @relation("IncubationUserChangeRequests", fields: [requestedById], references: [id])
  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  responses     ChangeResponse[]
}

model ChangeResponse {
  id              String        @id @default(cuid())
  changeRequestId String
  respondedById   String
  responseText    String?
  fileUrl         String?
  respondedAt     DateTime      @default(now())
  changeRequest   ChangeRequest @relation(fields: [changeRequestId], references: [id])
}

model DocumentRequest {
  id            String             @id @default(cuid())
  applicationId String
  tenantId      String
  requestedById String?
  requestedAt   DateTime           @default(now())
  resolvedAt    DateTime?
  title         String?
  description   String?
  status        RequestStatus      @default(PENDING)
  visibleToAll  Boolean            @default(true)
  application   StartupApplication @relation(fields: [applicationId], references: [id])
  requestedBy   IncubationUser?    @relation("IncubationUserDocumentRequests", fields: [requestedById], references: [id])
  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  responses     DocumentResponse[]
}

model DocumentResponse {
  id                String                 @id @default(cuid())
  documentRequestId String
  respondedById     String
  fileUrl           String
  comment           String?
  status            DocumentResponseStatus @default(SUBMITTED)
  respondedAt       DateTime               @default(now())
  documentRequest   DocumentRequest        @relation(fields: [documentRequestId], references: [id])
  files             DocumentResponseFile[]

  @@index([documentRequestId])
}

model DocumentResponseFile {
  id                 String           @id @default(cuid())
  documentResponseId String
  fileName           String
  fileUrl            String
  fileType           String?
  sizeBytes          Int?
  uploadedAt         DateTime         @default(now())
  documentResponse   DocumentResponse @relation(fields: [documentResponseId], references: [id], onDelete: Cascade)

  @@index([documentResponseId])
}

enum DocumentResponseStatus {
  SUBMITTED
  WITHDRAWN
}

model ApplicationHistory {
  id            String                    @id @default(cuid())
  applicationId String
  changedById   String?
  oldStatus     StartupApplicationStatus?
  newStatus     StartupApplicationStatus
  comment       String?
  changedAt     DateTime                  @default(now())
  application   StartupApplication        @relation(fields: [applicationId], references: [id])
}

model SchemeAnswer {
  id            String             @id @default(cuid())
  applicationId String
  questionId    String
  answerText    String?
  answerFileUrl String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  application   StartupApplication @relation(fields: [applicationId], references: [id])
  question      SchemeQuestion     @relation(fields: [questionId], references: [id])
}

model StartupFile {
  id            String              @id @default(cuid())
  startupId     String
  applicationId String?
  fileName      String
  fileUrl       String
  fileType      String?
  uploadedBy    String?
  uploadedAt    DateTime            @default(now())
  application   StartupApplication? @relation(fields: [applicationId], references: [id])
  startup       Startup             @relation(fields: [startupId], references: [id])
}

model StartupTenantAssociation {
  id           String              @id @default(cuid())
  startupId    String
  tenantId     String
  status       TenantStartupStatus @default(ONBOARDED)
  onboardedAt  DateTime?           @default(now())
  offboardedAt DateTime?
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  startup      Startup             @relation(fields: [startupId], references: [id])
  tenant       Tenant              @relation(fields: [tenantId], references: [id])

  @@unique([startupId, tenantId])
}

model StartupProgramAssociation {
  id                    String               @id @default(cuid())
  startupId             String
  programId             String
  tenantId              String
  batchId               String?
  status                StartupProgramStatus @default(ACTIVE)
  onboardedAt           DateTime?            @default(now())
  offboardedAt          DateTime?
  isActive              Boolean              @default(true)
  approvedFundingAmount Float?
  totalDisbursedAmount  Float?               @default(0)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  program               Program              @relation(fields: [programId], references: [id])
  startup               Startup              @relation(fields: [startupId], references: [id])
  tenant                Tenant               @relation(fields: [tenantId], references: [id])
  batch                 ProgramBatch?        @relation(fields: [batchId], references: [id])

  @@unique([startupId, programId, batchId])
  @@index([batchId])
}

// ============================================================================
// MODELS - FUNDING & INVESTMENT FLOW
// ============================================================================

model TenantFundingSource {
  id              String            @id @default(cuid())
  tenantId        String
  sourceName      String
  sourceType      FundingSourceType
  totalAmount     Float
  allocatedAmount Float             @default(0)
  currency        String            @default("INR")
  receivedDate    DateTime?
  expiryDate      DateTime?
  reference       String?
  notes           String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant      Tenant                     @relation(fields: [tenantId], references: [id])
  allocations ProgramFundingAllocation[]
