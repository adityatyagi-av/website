  childEventId   String   @unique
  instanceDate   DateTime
  instanceNumber Int
  createdAt      DateTime @default(now())
  parentEvent    Event    @relation("ParentEventInstances", fields: [parentEventId], references: [id], onDelete: Cascade)
  childEvent     Event    @relation("ChildEventInstances", fields: [childEventId], references: [id], onDelete: Cascade)

  @@index([parentEventId])
}

// Jobs
model Job {
  id               String          @id @default(cuid())
  title            String
  slug             String          @unique
  description      String
  requirements     String[]        @default([])
  responsibilities String[]        @default([])
  benefits         String[]        @default([])
  startupId        String?
  postedById       String
  jobType          JobType
  workMode         WorkMode
  experienceLevel  ExperienceLevel
  location         String?
  salaryMin        Float?
  salaryMax        Float?
  currency         String          @default("USD")
  salaryPeriod     SalaryPeriod    @default(YEARLY)
  showSalary       Boolean         @default(true)
  skills           String[]        @default([])
  status           JobStatus       @default(OPEN)
  applicationUrl   String?
  applicationEmail String?
  deadline         DateTime?
  viewCount        Int             @default(0)
  isFeatured       Boolean         @default(false)
  isRemote         Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  startup          Startup?        @relation(fields: [startupId], references: [id])
  postedBy         User            @relation(fields: [postedById], references: [id])
  page             Page?           @relation(fields: [pageId], references: [id])
  pageId           String?

  categoryId        String?
  category          JobCategory? @relation(fields: [categoryId], references: [id])
  department        String?
  industry          String?
  urgency           JobUrgency   @default(NORMAL)
  numberOfOpenings  Int          @default(1)
  applicationLimit  Int?
  requiredSkills    String[]     @default([])
  niceToHaveSkills  String[]     @default([])
  minimumExperience Int?
  maximumExperience Int?
  educationLevel    String?
  isConfidential    Boolean      @default(false)
  applicationCount  Int          @default(0)
  hiringManagerId   String?
  hiringManager     User?        @relation("JobHiringManager", fields: [hiringManagerId], references: [id])

  applications       JobApplication[]
  screeningQuestions JobScreeningQuestion[]
  views              JobView[]
  bookmarks          JobBookmark[]
  referrals          JobReferral[]

  @@index([slug])
  @@index([status])
  @@index([jobType])
  @@index([createdAt])
  @@index([pageId])
  @@index([categoryId])
  @@index([hiringManagerId])
  @@index([status, createdAt])
  @@index([experienceLevel, status])
  @@index([pageId, status])
}

model JobApplication {
  id           String               @id @default(cuid())
  jobId        String
  userId       String
  status       JobApplicationStatus @default(APPLIED)
  resumeUrl    String?
  coverLetter  String?
  portfolioUrl String?
  answers      Json?
  notes        String?
  appliedAt    DateTime             @default(now())
  reviewedAt   DateTime?
  updatedAt    DateTime             @updatedAt
  job          Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  matchScore        Float?
  screeningScore    Float?
  source            String?
  referralId        String?
  referral          JobReferral? @relation(fields: [referralId], references: [id])
  expectedSalary    Float?
  noticePeriod      String?
  currentlyEmployed Boolean?

  screeningAnswers JobScreeningAnswer[]
  applicationNotes ApplicationNote[]
  timeline         ApplicationTimeline[]
  ratings          ApplicationRating[]

  @@unique([jobId, userId])
  @@index([jobId])
  @@index([userId])
  @@index([status])
  @@index([jobId, status])
  @@index([matchScore])
}

model JobCategory {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  parentId  String?
  parent    JobCategory?  @relation("JobCategoryHierarchy", fields: [parentId], references: [id])
  children  JobCategory[] @relation("JobCategoryHierarchy")
  icon      String?
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  jobs      Job[]

  @@index([parentId])
  @@index([slug])
}

model JobScreeningQuestion {
  id             String                @id @default(cuid())
  jobId          String
  job            Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  questionText   String
  questionType   ScreeningQuestionType
  options        Json?
  isRequired     Boolean               @default(false)
  isEliminatory  Boolean               @default(false)
  expectedAnswer Json?
  orderIndex     Int                   @default(0)
  createdAt      DateTime              @default(now())
  answers        JobScreeningAnswer[]

  @@index([jobId])
}

model JobScreeningAnswer {
  id            String               @id @default(cuid())
  applicationId String
  application   JobApplication       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  questionId    String
  question      JobScreeningQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer        Json
  createdAt     DateTime             @default(now())

  @@unique([applicationId, questionId])
  @@index([applicationId])
}

model JobBookmark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

model JobView {
  id       String   @id @default(cuid())
  jobId    String
  job      Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  viewerId String?
  viewer   User?    @relation("JobViewer", fields: [viewerId], references: [id])
  source   String?
  viewedAt DateTime @default(now())

  @@index([jobId, viewedAt])
  @@index([viewerId])
}

model JobAlert {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  keywords         String[]          @default([])
  jobTypes         JobType[]
  workModes        WorkMode[]
  experienceLevels ExperienceLevel[]
  locations        String[]          @default([])
  skills           String[]          @default([])
  salaryMin        Float?
  salaryMax        Float?
  industries       String[]          @default([])
  categories       String[]          @default([])
  isRemoteOnly     Boolean           @default(false)
  frequency        JobAlertFrequency @default(DAILY)
  isActive         Boolean           @default(true)
  lastTriggeredAt  DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([userId, isActive])
}

model JobReferral {
  id             String         @id @default(cuid())
  jobId          String
  job            Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  referrerId     String
  referrer       User           @relation("JobReferrer", fields: [referrerId], references: [id])
  referredEmail  String
  referredUserId String?
  referredUser   User?          @relation("JobReferred", fields: [referredUserId], references: [id])
  note           String?
  status         ReferralStatus @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  applications JobApplication[]

  @@unique([jobId, referredEmail])
  @@index([referrerId])
  @@index([jobId])
}

model ApplicationNote {
  id            String         @id @default(cuid())
  applicationId String
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  authorId      String
  author        User           @relation("ApplicationNoteAuthor", fields: [authorId], references: [id])
  content       String
  isPrivate     Boolean        @default(false)
  createdAt     DateTime       @default(now())

  @@index([applicationId])
}

model ApplicationTimeline {
  id            String                @id @default(cuid())
  applicationId String
  application   JobApplication        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromStatus    JobApplicationStatus?
  toStatus      JobApplicationStatus
  changedById   String
  changedBy     User                  @relation("ApplicationTimelineChanger", fields: [changedById], references: [id])
  note          String?
  createdAt     DateTime              @default(now())

  @@index([applicationId])
}

model ApplicationRating {
  id            String         @id @default(cuid())
  applicationId String
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  raterId       String
  rater         User           @relation("ApplicationRater", fields: [raterId], references: [id])
  score         Int
  comment       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([applicationId, raterId])
  @@index([applicationId])
}

// Messaging
// Universal Chat - works for any entity pair
model Conversation {
  id String @id @default(cuid())

  // Participant 1
  participant1Type EntityType
  participant1Id   String

  // Participant 2
  participant2Type EntityType
  participant2Id   String

  // Context
  contextType ConversationContext @default(GENERAL)
  contextId   String? // mentorshipId, projectId, etc.

  // Status
  isActive  Boolean @default(true)
  isBlocked Boolean @default(false)
  blockedBy String?

  // Stats
  totalMessages Int       @default(0)
  lastMessageAt DateTime?
  lastMessageBy String?
  unreadCount1  Int       @default(0)
  unreadCount2  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@unique([participant1Type, participant1Id, participant2Type, participant2Id, contextType, contextId])
  @@index([participant1Type, participant1Id])
  @@index([participant2Type, participant2Id])
  @@index([contextType, contextId])
  @@index([lastMessageAt])
}

model Message {
  id             String @id @default(cuid())
  conversationId String

  // Sender
  senderType EntityType
  senderId   String

  // Content
  content     String?
  messageType MessageType @default(TEXT)
  attachments Json?

  // Reply
  replyToId String?

  // Status
  isRead    Boolean   @default(false)
  readAt    DateTime?
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  isEdited  Boolean   @default(false)
  editedAt  DateTime?

  // Metadata
  metadata Json?

  createdAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  replyTo      Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]    @relation("MessageReplies")

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

// Mentorship
model MentorProfile {
  id     String @id @default(cuid())
  userId String @unique

  // --- EXISTING FIELDS ---
  title              String?
  company            String?
  yearsExperience    Int?
  expertise          String[]  @default([])
  industries         String[]  @default([])
  focusAreas         String[]  @default([])
  languages          String[]  @default(["English"])
  timezone           String?
  rating             Float?
  reviewCount        Int       @default(0)
  totalMentees       Int       @default(0)
  activeMentees      Int       @default(0)
  isProBonoAvailable Boolean   @default(false)
  proBonoSlots       Int       @default(0)
  proBonoCriteria    String?
  bio                String?
  mentoringSince     DateTime?
  isAccepting        Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // --- NEW FIELDS ---
  headline          String?
  mentoringApproach String?
  successStories    Json?
  backgroundSummary String?
  startupStages     String[] @default([])

  // Stats
  totalSessions     Int  @default(0)
  completedSessions Int  @default(0)
  successfulExits   Int  @default(0)
  startupsHelped    Int  @default(0)
  responseTimeHours Int?

  // Verification
  verificationStatus MentorVerificationStatus @default(PENDING)
  profileVisibility  MentorProfileVisibility  @default(PUBLIC)
  isFeatured         Boolean                  @default(false)
  featuredUntil      DateTime?

  // Booking Settings
  minBookingNotice      Int     @default(24)
  maxBookingsPerDay     Int?
  autoConfirm           Boolean @default(false) // FALSE by default
  bufferBetweenSessions Int     @default(15)
  freeCancellationHours Int     @default(24)

  // NO VIDEO PLATFORM FIELDS - Internal Jitsi only

  // Relations
  user                  User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionTypes          SessionType[]
  availability          MentorAvailability[]
  sessions              MentorSession[]              @relation("MentorProfileSessions")
  reviews               MentorReview[]
  contentItems          MentorContent[]
  packages              MentorPackage[]
  incubatorAssociations IncubatorMentorAssociation[]
  mentorships           Mentorship[]
  calendarSyncs         MentorCalendarSync[]

  @@index([verificationStatus])
  @@index([isFeatured])
  @@index([rating])
}

model SessionType {
  id          String          @id @default(cuid())
  mentorId    String
  name        String
  description String?
  duration    Int
  price       Float           @default(0)
  currency    String          @default("USD")
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  mentor      MentorProfile   @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  sessions    MentorSession[]

  @@index([mentorId])
}

model MentorAvailability {
  id        String        @id @default(cuid())
  mentorId  String
  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  mentor    MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@index([mentorId])
}

model MentorSession {
  id            String  @id @default(cuid())
  mentorId      String
  sessionTypeId String?

  // Mentee (User or Startup)
  menteeType MenteeType @default(USER)
  menteeId   String
  userId     String?
  startupId  String?

  // Scheduling
  title           String?
  description     String?
  startTime       DateTime
  endTime         DateTime
  actualStartTime DateTime?
  actualEndTime   DateTime?
  duration        Int // Planned duration in minutes
  actualDuration  Int?
  timezone        String    @default("Asia/Kolkata")

  // Meeting - INTERNAL JITSI ONLY
  meetingRoomId String? // Jitsi room ID
  meetingUrl    String? // Generated Jitsi URL

  // ========== SESSION EXTENSION (NEW) ==========
  isExtended          Boolean   @default(false)
  originalDuration    Int? // Original booked duration
  extensionMinutes    Int? // Minutes extended (max 30)
  extensionFree       Boolean   @default(true) // Free or paid extension?
  extensionAmount     Float? // If paid, extra amount charged
  extensionApprovedAt DateTime?
  // =============================================

  // Agenda & Notes
  agenda          String?
  preSessionNotes String?
  sessionNotes    String?
  actionItems     Json?

  // Status
  status    MentorSessionStatus @default(PENDING)
  price     Float               @default(0)
  currency  String              @default("INR")
  paymentId String?
  notes     String?
  feedback  String?
  rating    Int?

  // Cancellation
  cancelledAt     DateTime?
  cancelReason    String?
  cancelledBy     String?
  cancelledByRole String?
  refundAmount    Float?
  refundStatus    RefundStatus?
  refundId        String?

  // Booking Context
  bookingContext         BookingContext @default(DIRECT)
  mentorshipId           String?
  incubatorAssociationId String?
  packageSubscriptionId  String?

  // Payment Details
  paymentStatus      SessionPaymentStatus @default(PENDING)
  grossAmount        Float                @default(0)
  platformFee        Float                @default(0)
  platformFeePercent Float                @default(10)
  mentorPayout       Float                @default(0)
  paidBy             PaidBy?
  incubatorShare     Float?
  startupShare       Float?

  // Review
  reviewSubmitted   Boolean   @default(false)
  reviewSubmittedAt DateTime?

  // Recording (Premium only)
  isRecorded       Boolean @default(false)
  recordingConsent Boolean @default(false)

  // Reminders
  reminder24hSent Boolean @default(false)
  reminder1hSent  Boolean @default(false)

  // Completion
  completedAt     DateTime?
  completionNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  mentor               MentorProfile               @relation("MentorProfileSessions", fields: [mentorId], references: [id], onDelete: Cascade)
  menteeUser           User?                       @relation("MenteeSessions", fields: [userId], references: [id], onDelete: Cascade)
  sessionType          SessionType?                @relation(fields: [sessionTypeId], references: [id])
  menteeStartup        Startup?                    @relation("StartupMentorSessions", fields: [startupId], references: [id])
  mentorship           Mentorship?                 @relation(fields: [mentorshipId], references: [id])
  incubatorAssociation IncubatorMentorAssociation? @relation(fields: [incubatorAssociationId], references: [id])
  packageSubscription  PackageSubscription?        @relation(fields: [packageSubscriptionId], references: [id])
  recordings           SessionRecording[]
  earning              MentorEarning?

  @@index([mentorId])
  @@index([userId])
  @@index([startupId])
  @@index([startTime])
  @@index([status])
  @@index([bookingContext])
}

model MentorPackage {
  id                      String      @id @default(cuid())
  mentorProfileId         String
  name                    String
  description             String?
  packageType             PackageType
  sessionsIncluded        Int
  sessionDuration         Int?
  validityDays            Int
  price                   Float
  originalPrice           Float?
  currency                String      @default("INR")
  discountPercent         Float?
  features                String[]    @default([])
  includesChat            Boolean     @default(false)
  includesPriorityBooking Boolean     @default(false)
  isActive                Boolean     @default(true)
  displayOrder            Int         @default(0)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  mentor        MentorProfile         @relation(fields: [mentorProfileId], references: [id], onDelete: Cascade)
  subscriptions PackageSubscription[]

  @@index([mentorProfileId])
  @@index([isActive])
}

model PackageSubscription {
  id                String                    @id @default(cuid())
  packageId         String
  subscriberType    MenteeType
  subscriberId      String
  userId            String?
  startupId         String?
  purchasedAt       DateTime                  @default(now())
  expiresAt         DateTime
  amountPaid        Float
  currency          String                    @default("INR")
  razorpayPaymentId String?
  razorpayOrderId   String?
  paymentStatus     PaymentStatus             @default(PENDING)
  sessionsTotal     Int
  sessionsUsed      Int                       @default(0)
  sessionsRemaining Int
  status            PackageSubscriptionStatus @default(ACTIVE)
  cancelledAt       DateTime?
  cancelReason      String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  package  MentorPackage   @relation(fields: [packageId], references: [id])
  user     User?           @relation(fields: [userId], references: [id])
  startup  Startup?        @relation(fields: [startupId], references: [id])
  sessions MentorSession[]

  @@index([packageId])
  @@index([userId])
  @@index([startupId])
  @@index([status])
}

model IncubatorMentorAssociation {
  id                    String                @id @default(cuid())
  mentorProfileId       String
  tenantId              String
  status                AssociationStatus     @default(PENDING)
  initiatedBy           AssociationInitiator
  initiatedAt           DateTime              @default(now())
  approvedAt            DateTime?
  approvedBy            String?
  paymentModel          IncubatorPaymentModel
  agreedRate            Float?
  retainerAmount        Float?
  retainerHours         Float?
  incubatorSharePercent Float?
  startDate             DateTime?
  endDate               DateTime?
  isExclusive           Boolean               @default(false)
  notes                 String?
  hoursUsedThisMonth    Float                 @default(0)
  hoursUsedTotal        Float                 @default(0)
  lastResetDate         DateTime?
  autoApproveBookings   Boolean               @default(false)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  endedAt               DateTime?
  endedBy               String?
  endReason             String?

  mentor      MentorProfile   @relation(fields: [mentorProfileId], references: [id], onDelete: Cascade)
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions    MentorSession[]
  earnings    MentorEarning[]
  mentorships Mentorship[]

  @@unique([mentorProfileId, tenantId])
  @@index([mentorProfileId])
  @@index([tenantId])
  @@index([status])
}

model Mentorship {
  id                     String            @id @default(cuid())
  mentorProfileId        String
  menteeType             MenteeType
  userId                 String?
  startupId              String?
  engagementType         EngagementType
  incubatorAssociationId String?
  programId              String?
  status                 MentorshipStatus  @default(PENDING)
  startDate              DateTime?
  endDate                DateTime?
  frequency              MeetingFrequency?
  nextSessionDate        DateTime?
  objectives             String?
  goals                  Json?
  mentorNotes            String?
  totalSessions          Int               @default(0)
  lastSessionDate        DateTime?
  isEquityBased          Boolean           @default(false)
  equityPercent          Float?
  equityNotes            String?

  // Chat - Link to Universal Conversation
  conversationId String? // Link to Conversation model

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  endedAt   DateTime?
  endedBy   String?
  endReason String?

  mentor               MentorProfile               @relation(fields: [mentorProfileId], references: [id], onDelete: Cascade)
  user                 User?                       @relation("UserMentorships", fields: [userId], references: [id])
  startup              Startup?                    @relation("StartupMentorships", fields: [startupId], references: [id])
  incubatorAssociation IncubatorMentorAssociation? @relation(fields: [incubatorAssociationId], references: [id])
  sessions             MentorSession[]
  milestones           MentorshipMilestone[]

  @@index([mentorProfileId])
  @@index([userId])
  @@index([startupId])
  @@index([status])
}

model MentorshipMilestone {
  id              String                    @id @default(cuid())
  mentorshipId    String
  title           String
  description     String?
  targetDate      DateTime?
  status          MentorshipMilestoneStatus @default(PENDING)
  progress        Int                       @default(0)
  completedAt     DateTime?
  completionNotes String?
  displayOrder    Int                       @default(0)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  mentorship Mentorship @relation(fields: [mentorshipId], references: [id], onDelete: Cascade)

  @@index([mentorshipId])
  @@index([status])
}

model SessionRecording {
  id                 String          @id @default(cuid())
  sessionId          String
  recordingUrl       String
  duration           Int?
  fileSize           Int?
  format             String          @default("webm")
  recordedBy         String
  isPremiumRecording Boolean         @default(true)
  status             RecordingStatus @default(PROCESSING)
  processedAt        DateTime?
  isAccessible       Boolean         @default(true)
  expiresAt          DateTime?
  createdAt          DateTime        @default(now())

  session MentorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model MentorCalendarSync {
  id               String           @id @default(cuid())
  mentorProfileId  String
  provider         CalendarProvider
  accessToken      String?
  refreshToken     String?
  tokenExpiresAt   DateTime?
  calendarId       String?
  calendarName     String?
  syncEnabled      Boolean          @default(true)
  readEvents       Boolean          @default(true)
  writeEvents      Boolean          @default(true)
  lastSyncAt       DateTime?
  lastSyncStatus   SyncStatus       @default(PENDING)
  syncError        String?
  webhookChannelId String?
  webhookExpiry    DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  mentor MentorProfile @relation(fields: [mentorProfileId], references: [id], onDelete: Cascade)

  @@unique([mentorProfileId, provider])
  @@index([mentorProfileId])
}

model MentorReview {
  id         String        @id @default(cuid())
  mentorId   String
  reviewerId String
  sessionId  String?
  rating     Int
  review     String?
  isPublic   Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  mentor     MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@index([mentorId])
}

model MentorContent {
  id          String        @id @default(cuid())
  mentorId    String
  title       String
  description String?
  type        ContentType
  url         String
  thumbnail   String?
  viewCount   Int           @default(0)
  isPublic    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  mentor      MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@index([mentorId])
}

// Notifications
model Notification {
  id          String               @id @default(cuid())
  userId      String
  type        NotificationType
  category    NotificationCategory @default(SYSTEM)
  priority    NotificationPriority @default(MEDIUM)
  title       String
  message     String
  data        Json?
  isRead      Boolean              @default(false)
  readAt      DateTime?
  actionUrl   String?
  actorId     String?
  actorName   String?
  actorAvatar String?
  entityType  String?
  entityId    String?
  groupKey    String?
  isArchived  Boolean              @default(false)
  expiresAt   DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, isArchived, createdAt])
  @@index([userId, category, createdAt])
  @@index([groupKey])
  @@index([entityType, entityId])
  @@index([expiresAt])
}

model NotificationPreference {
  id        String               @id @default(cuid())
  userId    String
  category  NotificationCategory
  inApp     Boolean              @default(true)
  email     Boolean              @default(true)
  push      Boolean              @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
}

// Gamification
model GamificationProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  totalPoints    Int       @default(0)
  currentLevel   Int       @default(1)
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActivityAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id          String              @id @default(cuid())
  name        String              @unique
  description String
  category    AchievementCategory
  icon        String?
  points      Int                 @default(0)
  tier        AchievementTier     @default(BRONZE)
  criteria    Json
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  progress      Int         @default(0)
  isCompleted   Boolean     @default(false)
  completedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model Badge {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  icon        String?
  category    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PointTransaction {
  id          String          @id @default(cuid())
  userId      String
  points      Int
  type        PointActionType
  description String?
  referenceId String?
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// Security and Sessions
model UserSession {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  deviceInfo   String?
  ipAddress    String?
  userAgent    String?
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model LoginHistory {
  id         String   @id @default(cuid())
  userId     String
  ipAddress  String?
  userAgent  String?
  deviceInfo String?
  location   String?
  status     String   @default("success")
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// Reporting and Moderation
model Report {
  id             String       @id @default(cuid())
  reporterId     String
  reportedUserId String?
  contentType    String
  contentId      String
  reason         ReportReason
  description    String?
