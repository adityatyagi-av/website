  @@index([communityId])
  @@index([userId])
  @@index([communityId, role])
  @@index([communityId, isBanned])
}

model CommunityPost {
  id            String                  @id @default(cuid())
  communityId   String
  channelId     String?
  authorId      String
  title         String?
  content       String
  postType      CommunityPostType       @default(TEXT)
  mediaUrls     String[]                @default([])
  linkPreview   Json?
  isPinned      Boolean                 @default(false)
  isApproved    Boolean                 @default(true)
  isEdited      Boolean                 @default(false)
  editedAt      DateTime?
  isArchived    Boolean                 @default(false)
