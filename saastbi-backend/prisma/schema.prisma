model TenantProfile {
  id       String @id @default(cuid())
  tenantId String @unique

  // Identity & Branding
  bannerColor String?

  // Contact & Location
  address   String?
  city      String?
  state     String?
  country   String?
  pincode   String?
  latitude  Float?
  longitude Float?
  timezone  String?

  // Social Links (extras not on Page)
  facebook  String?
  instagram String?
  youtube   String?

  // Incubation Classification
  incubationType     IncubationType?
  focusStages        String[]         @default([])
  affiliationType    AffiliationType?
  parentOrganization String?
  registrationNumber String?
  incorporationType  String?

  // Infrastructure & Capacity
  totalAreaSqFt              Float?
  seatingCapacity            Int?
  labsAvailable              Boolean  @default(false)
  labDetails                 String?
  coworkingAvailable         Boolean  @default(false)
  meetingRooms               Int?
  eventSpaceCapacity         Int?
  amenities                  String[] @default([])
  virtualIncubationAvailable Boolean  @default(false)

  // Program & Operations
  isAcceptingApplications Boolean  @default(false)
  applicationProcess      String?
  typicalProgramDuration  String?
  maxStartupsPerBatch     Int?
  selectionCriteria       String?
  equityRequired          Boolean  @default(false)
  equityRangeMin          Float?
  equityRangeMax          Float?
  stipendAvailable        Boolean  @default(false)
  stipendAmount           Float?
  stipendCurrency         String?  @default("INR")
  servicesOffered         String[] @default([])
  supportType             String[] @default([])

  // Funding & Financial
  fundingCurrency          String?  @default("INR")
  fundingSources           String[] @default([])
  averageFundingPerStartup Float?
  hasSeedFunding           Boolean  @default(false)
  hasFollowOnFunding       Boolean  @default(false)

  // Network & Partnerships
  industryPartners          String[] @default([])
  investorPartners          String[] @default([])
  academicPartners          String[] @default([])
  governmentPartners        String[] @default([])
  corporatePartners         String[] @default([])
  internationalPartnerships String[] @default([])
  networkMemberships        String[] @default([])

  // Impact & Metrics (manually maintained)
  successfulExits            Int?    @default(0)
  totalJobsCreated           Int?    @default(0)
  totalRevenueGenerated      Float?
  totalIPsFiled              Int?    @default(0)
  successRate                Float?
  averageGraduationTime      String?
  startupsWithFunding        Int?    @default(0)
  totalExternalFundingRaised Float?

  // Recognition & Credibility
  certifications          String[]  @default([])
  awards                  String[]  @default([])
  rankings                String[]  @default([])
  mediaFeatures           String[]  @default([])
  isGovernmentRecognized  Boolean   @default(false)
  governmentRecognitionId String?
  isVerified              Boolean   @default(false)
  verifiedAt              DateTime?

  // Preferences & Settings
  defaultCurrency         String? @default("INR")
  defaultLanguage         String? @default("en")
  operatingHours          Json?
  holidayCalendar         Json?
  autoApproveApplications Boolean @default(false)
  requireNDA              Boolean @default(false)
  ndaTemplateUrl          String?
  brandPrimaryColor       String?
  brandSecondaryColor     String?

  // Content & Media
  gallery        String[] @default([])
  introVideoUrl  String?
  testimonials   Json?
  successStories Json?
  faqContent     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ============================================================================
// MODELS - DATA COLLECTION / FORM REQUEST SYSTEM
// ============================================================================

enum DataCollectionRequestType {
  FORM
  FILE_UPLOAD
  MIXED
}

enum DataCollectionTargetType {
  ASSOCIATED
  APPLICANT
}

enum DataCollectionRequestStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum DataCollectionAssignmentStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  RESUBMIT_REQUESTED
}

enum DataCollectionQuestionType {
  TEXT
  LONG_TEXT
  FILE_UPLOAD
  NUMBER
  BOOLEAN
  DATE
}

model DataCollectionRequest {
  id            String                      @id @default(cuid())
  programId     String
  batchId       String?
  tenantId      String
  requestedById String
  title         String
  description   String?
  requestType   DataCollectionRequestType   @default(MIXED)
  targetType    DataCollectionTargetType    @default(ASSOCIATED)
  status        DataCollectionRequestStatus @default(ACTIVE)
  dueDate       DateTime?
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  program     Program                    @relation(fields: [programId], references: [id])
  batch       ProgramBatch?              @relation(fields: [batchId], references: [id])
  tenant      Tenant                     @relation(fields: [tenantId], references: [id])
  requestedBy IncubationUser             @relation(fields: [requestedById], references: [id])
  assignments DataCollectionAssignment[]
  questions   DataCollectionQuestion[]

  @@index([programId])
  @@index([batchId])
  @@index([tenantId])
  @@index([status])
}

model DataCollectionQuestion {
  id           String                     @id @default(cuid())
  requestId    String
  questionText String
  questionType DataCollectionQuestionType
  isRequired   Boolean                    @default(false)
  options      Json?
  order        Int                        @default(0)

  request   DataCollectionRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  responses DataCollectionResponse[]

  @@index([requestId])
}

model DataCollectionAssignment {
  id                      String                         @id @default(cuid())
  dataCollectionRequestId String
  startupId               String
  applicationId           String?
  status                  DataCollectionAssignmentStatus @default(PENDING)
  submittedAt             DateTime?
  reviewedAt              DateTime?
  reviewedById            String?
  reviewNote              String?
  createdAt               DateTime                       @default(now())
  updatedAt               DateTime                       @updatedAt

  dataCollectionRequest DataCollectionRequest    @relation(fields: [dataCollectionRequestId], references: [id])
  startup               Startup                  @relation(fields: [startupId], references: [id])
  application           StartupApplication?      @relation(fields: [applicationId], references: [id])
  responses             DataCollectionResponse[]

  @@unique([dataCollectionRequestId, startupId])
  @@index([startupId])
  @@index([applicationId])
  @@index([status])
}

model DataCollectionResponse {
  id            String   @id @default(cuid())
  assignmentId  String
  questionId    String?
  respondedById String
  responseText  String?
  fileUrl       String?
  fileName      String?
  respondedAt   DateTime @default(now())

  assignment DataCollectionAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  question   DataCollectionQuestion?  @relation(fields: [questionId], references: [id])

  @@index([assignmentId])
  @@index([questionId])
}

model IncubationPayoutAccount {
  id                            String                   @id @default(cuid())
  tenantId                      String                   @unique
  legalBusinessName             String
  businessType                  String?
  accountHolderName             String
  bankAccountNumber             String
  bankIfscCode                  String
  bankName                      String?
  bankBranch                    String?
  gstNumber                     String?
  panNumber                     String?
  contactEmail                  String
  contactPhone                  String
  addressLine1                  String?
  addressLine2                  String?
  city                          String?
  state                         String?
  country                       String?                  @default("IN")
  pincode                       String?
  razorpayLinkedAccountId       String?
  razorpayStakeholderId         String?
  razorpayProductConfigurationId String?
  razorpayContactId             String?
  razorpayFundAccountId         String?
  kycStatus                     KycStatus                @default(PENDING)
  kycRejectionReason            String?
  kycSubmittedAt                DateTime?
  activatedAt                   DateTime?
  isPrimary                     Boolean                  @default(true)
  isActive                      Boolean                  @default(true)
  createdAt                     DateTime                 @default(now())
  updatedAt                     DateTime                 @updatedAt
  tenant                        Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents                     IncubationKycDocument[]
  payouts                       OfficePayout[]

  @@index([tenantId])
  @@index([kycStatus])
}

model IncubationKycDocument {
  id                  String                  @id @default(cuid())
  payoutAccountId     String
  documentType        String
  s3Url               String
  fileName            String?
  verificationStatus  String                  @default("PENDING")
  verifiedAt          DateTime?
  notes               String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  payoutAccount       IncubationPayoutAccount @relation(fields: [payoutAccountId], references: [id], onDelete: Cascade)

  @@index([payoutAccountId])
}

model OfficeSubscription {
  id                     String                    @id @default(cuid())
  bookingId              String                    @unique
  tenantId               String
  startupId              String?
  officeId               String
  pricingId              String
  razorpayPlanId         String?
  razorpaySubscriptionId String?                   @unique
  razorpayCustomerId     String?
  shortUrl               String?
  paymentMode            OfficePaymentMode         @default(SUBSCRIPTION)
  billingCycle           OfficeBillingCycle
  customCycleDays        Int?
  totalCount             Int
  paidCount              Int                       @default(0)
  remainingCount         Int
  currentStart           DateTime?
  currentEnd             DateTime?
  nextChargeAt           DateTime?
  endAt                  DateTime?
  status                 OfficeSubscriptionStatus  @default(PENDING)
  cancelledAt            DateTime?
  pausedAt               DateTime?
  metadata               Json?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  booking                OfficeBooking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tenant                 Tenant                    @relation(fields: [tenantId], references: [id])
  pricing                OfficePricing             @relation(fields: [pricingId], references: [id])
  payments               OfficePayment[]

  @@index([tenantId])
  @@index([status])
  @@index([nextChargeAt])
}

model OfficePayout {
  id                   String                  @id @default(cuid())
  tenantId             String
  payoutAccountId      String?
  paymentId            String?
  razorpayTransferId   String?                 @unique
  razorpaySettlementId String?
  amount               Float
  currency             String                  @default("INR")
  status               OfficePayoutStatus      @default(CREATED)
  payoutDate           DateTime?
  failureReason        String?
  metadata             Json?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  tenant               Tenant                  @relation(fields: [tenantId], references: [id])
  payoutAccount        IncubationPayoutAccount? @relation(fields: [payoutAccountId], references: [id])
  payment              OfficePayment?          @relation(fields: [paymentId], references: [id])

  @@index([tenantId, status])
  @@index([paymentId])
  @@index([payoutDate])
}

model WebhookEventLog {
  id          String    @id @default(cuid())
  provider    String
  eventId     String    @unique
  eventType   String
  payload     Json
  status      String    @default("PENDING")
  error       String?
  attempts    Int       @default(0)
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([provider, eventType])
  @@index([status])
}

enum OfficePaymentMode {
  ONE_TIME
  SUBSCRIPTION
}

enum OfficeBillingCycle {
  WEEKLY
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  CUSTOM
}

enum KycStatus {
  PENDING
  UNDER_REVIEW
  NEEDS_CLARIFICATION
  ACTIVATED
  REJECTED
  SUSPENDED
}

enum OfficeSubscriptionStatus {
  PENDING
  AUTHENTICATED
  ACTIVE
  PAUSED
  HALTED
  CANCELLED
  COMPLETED
  EXPIRED
}

enum OfficePayoutStatus {
  CREATED
  PENDING
  PROCESSED
  REVERSED
  FAILED
}
