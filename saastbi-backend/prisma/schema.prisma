model EventPoll {
  id         String          @id @default(cuid())
  eventId    String
  question   String
  options    Json
  isActive   Boolean         @default(true)
  totalVotes Int             @default(0)
  createdAt  DateTime        @default(now())
  endedAt    DateTime?
  event      Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  votes      EventPollVote[]

  @@index([eventId])
