  userId         String
  selectedOption Int
  createdAt      DateTime  @default(now())
  poll           EventPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user           User      @relation("UserEventPollVotes", fields: [userId], references: [id])

  @@unique([pollId, userId])
}

model EventRecurrenceInstance {
