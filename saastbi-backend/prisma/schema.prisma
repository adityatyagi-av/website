model Page {
  id          String   @id @default(cuid())
  creatorId   String
  name        String
  slug        String   @unique
  type        PageType
  tagline     String?
  description String?
  logo        String?
  coverImage  String?

  // Common fields
  sector       String?
  stage        String?
  foundedYear  Int?
  headquarters String?
  teamSize     String?
  website      String?
  linkedin     String?
  twitter      String?
  email        String?
  phone        String?

  // Startup specific fields
  mission       String?
  vision        String?
  elevatorPitch String?
  targetMarket  String?

  // VC Firm specific fields
  checkSizeMin       Float?
  checkSizeMax       Float?
  investmentStages   String[] @default([])
  focusSectors       String[] @default([])
  fundVintage        String?
  portfolioCount     Int?
  notableInvestments String?
  investmentThesis   String?
  aum                String?

  // Institution specific fields
  institutionType String?
  studentCount    Int?
  facultyCount    Int?
  accreditations  String?
  researchAreas   String[] @default([])

  // Company specific fields
  revenueRange String?
  keyServices  String?

  // Organization specific fields
  membershipSize String?
  keyInitiatives String?

  // Others specific fields
  othersCategory     String? // NGO, Club, Local Community, Alumni Group, etc.
  verificationStatus PageVerificationStatus @default(NOT_STARTED)
  visibility         PageVisibility         @default(PUBLIC)
  isHiring           Boolean                @default(false)
  openPositions      Int                    @default(0)
  followerCount      Int                    @default(0)
  isActive           Boolean                @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  creator           User                @relation("UserCreatedPages", fields: [creatorId], references: [id])
  followers         PageFollower[]
  members           PageMember[]
  posts             Post[]
