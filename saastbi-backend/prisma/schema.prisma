  updatedAt    DateTime  @updatedAt
  user         User      @relation("NetworkingUser", fields: [userId], references: [id], onDelete: Cascade)
  target       User      @relation("NetworkingTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([userId, targetUserId, matchType])
