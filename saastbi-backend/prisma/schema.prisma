  shares        CommunityPostShare[]
  mentions      CommunityPostMention[]
  hashtags      CommunityPostHashtag[]

  @@index([communityId])
  @@index([channelId])
  @@index([authorId])
  @@index([createdAt])
  @@index([communityId, isPinned])
  @@index([communityId, isApproved])
}

model CommunityComment {
  id        String                 @id @default(cuid())
