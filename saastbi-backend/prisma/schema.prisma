model PublicRepository {
  id                 String           @id @default(cuid())
  tenantId           String
  name               String
  slug               String
  description        String?
  apiKey             String           @unique
  status             RepositoryStatus @default(ACTIVE)
  schema             Json
  isRateLimited      Boolean          @default(true)
  rateLimitPerMinute Int              @default(60)
  totalItems         Int              @default(0)
  creatorId          String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  tenant     Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items      RepositoryItem[]
  accessLogs RepositoryAccessLog[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([apiKey])
  @@index([tenantId, status])
}

model RepositoryItem {
  id           String   @id @default(cuid())
  repositoryId String
  data         Json
  orderIndex   Int      @default(0)
  isActive     Boolean  @default(true)
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  repository PublicRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId])
  @@index([repositoryId, isActive])
  @@index([createdAt])
}

model RepositoryAccessLog {
  id           String   @id @default(cuid())
  repositoryId String
  ipAddress    String?
  userAgent    String?
  endpoint     String?
  responseTime Int?
  createdAt    DateTime @default(now())

  repository PublicRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId, createdAt])
  @@index([ipAddress, createdAt])
}

model LinkedAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  email             String?
  displayName       String?
  profilePhoto      String?
  rawProfile        Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
}

